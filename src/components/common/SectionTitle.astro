---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { eyebrow, title, description, centered = false } = Astro.props as Props;
---

<div class:list={['max-w-3xl', centered && 'mx-auto text-center']}>
  <span class="section-kicker">{eyebrow}</span>
  <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-muted">{description}</p>}
</div>
