---
import { Image } from 'astro:assets';
import moduleBedBath from '../../assets/product/module-bed-bath.svg';
import modulePerinealCare from '../../assets/product/module-perineal-care.svg';
import dashboardScore from '../../assets/product/dashboard-score.svg';

const previews = [
  {
    title: '訓練情境',
    description: '床上清潔情境以教學導向畫面呈現，方便學員先理解流程與照護節點。',
    image: moduleBedBath,
    alt: 'CareMirror 訓練情境畫面，展示床上清潔流程',
    width: 720,
    height: 480,
  },
  {
    title: '模組操作',
    description: '會陰照護流程被拆解成可示教、可判定的模組操作，降低高敏感度情境的學習壓力。',
    image: modulePerinealCare,
    alt: 'CareMirror 模組操作畫面，展示會陰照護互動流程',
    width: 640,
    height: 420,
  },
  {
    title: '評分系統',
    description: '透過 dashboard 彙整步驟結果、錯誤紀錄與補訓方向，讓回饋更具依據。',
    image: dashboardScore,
    alt: 'CareMirror 評分系統畫面，展示訓練結果與 dashboard',
    width: 640,
    height: 420,
  },
];
---

<div class="grid gap-6 lg:grid-cols-[1.06fr_0.94fr]">
  <article class="panel overflow-hidden p-5 sm:p-6">
    <Image
      src={previews[0].image}
      alt={previews[0].alt}
      width={previews[0].width}
      height={previews[0].height}
      loading="lazy"
      class="h-auto w-full rounded-2xl border border-white/10 bg-slate-950/40 object-cover" />
    <div class="mt-5">
      <h3 class="text-2xl font-semibold text-white">{previews[0].title}</h3>
      <p class="mt-3 text-sm leading-7 text-muted">{previews[0].description}</p>
    </div>
  </article>

  <div class="grid gap-6">
    {
      previews.slice(1).map((item) => (
        <article class="panel grid gap-5 overflow-hidden p-5 sm:grid-cols-[0.9fr_1.1fr] sm:items-center sm:p-6">
          <Image
            src={item.image}
            alt={item.alt}
            width={item.width}
            height={item.height}
            loading="lazy"
            class="h-full w-full rounded-2xl border border-white/10 bg-slate-950/40 object-cover" />
          <div>
            <h3 class="text-xl font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{item.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</div>
