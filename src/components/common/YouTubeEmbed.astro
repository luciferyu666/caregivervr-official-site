---
interface Props {
  videoId: string;
  title: string;
  description?: string;
  watchUrl?: string;
  class?: string;
  eager?: boolean;
}

const props = Astro.props as Props;
const videoId = props.videoId;
const title = props.title;
const description = props.description;
const watchUrl = props.watchUrl ?? `https://www.youtube.com/watch?v=${videoId}`;
const className = props.class ?? '';
const eager = props.eager ?? false;
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1&playsinline=1`;
---

<article class={`panel overflow-hidden p-4 sm:p-5 ${className}`.trim()}>
  <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-slate-950/70">
    <div class="aspect-video">
      <iframe
        class="h-full w-full"
        src={embedUrl}
        title={title}
        loading={eager ? 'eager' : 'lazy'}
        referrerpolicy="strict-origin-when-cross-origin"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
  </div>
  <div class="px-1 pb-1 pt-5">
    <h3 class="text-xl font-semibold text-white">{title}</h3>
    {description && <p class="mt-3 text-sm leading-7 text-muted">{description}</p>}
    <a
      class="mt-5 inline-flex items-center text-sm font-semibold text-brand-200"
      href={watchUrl}
      target="_blank"
      rel="noreferrer">
      在 YouTube 觀看
      <span class="ml-2 text-lg">→</span>
    </a>
  </div>
</article>
